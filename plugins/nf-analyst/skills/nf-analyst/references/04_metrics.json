{"metrics":[
{"m":"Active Customers","syn":["ordering customers","transacting users"],"sql":"COUNT(DISTINCT customer_id)","src":"daily_orders","filters":["order_status='delivered'","country='ae'"],"note":"New+Repeat=Active; validate if computing all 3"},
{"m":"New Customers","syn":["FTU","first time users","new users"],"sql":"COUNT(DISTINCT customer_id) WHERE rn=1","derive":"ROW_NUMBER() OVER (PARTITION BY customer_id ORDER BY day)=1 on delivered orders","src":"daily_orders","filters":["order_status='delivered'","country='ae'"]},
{"m":"Repeat Customers","syn":["returning customers","existing customers"],"sql":"COUNT(DISTINCT customer_id) WHERE rn<>1","src":"daily_orders","filters":["order_status='delivered'","country='ae'"]},
{"m":"GMV","syn":["gross merchandise value","revenue","basket total"],"sql":"SUM(GMV)","src":"daily_orders","filters":["order_status='delivered'"],"note":"≠ total_order_amount (includes fees) ≠ Amount_Payable"},
{"m":"AOV","syn":["average order value","average basket","basket size"],"sql":"SAFE_DIVIDE(SUM(GMV),COUNT(DISTINCT order_id))","src":"daily_orders","filters":["order_status='delivered'"]},
{"m":"Sessions","syn":["app opens","visits"],"sql":"COUNT(DISTINCT sid)","src":"nat_events_complete","filters":["locale LIKE '%ae%'","always filter day"],"note":"For hub/city use daily_hubz_rca_nat.Food_Sessions — cheaper"},
{"m":"Relevant Sessions","syn":["engaged sessions","non-bounce sessions"],"sql":"COUNT(DISTINCT sid) WHERE is_bounce<>1 AND is_moved<>1","src":"session_segments_nat","note":"For daily hub level: daily_hubz_rca_nat.Relevant_Sessions"},
{"m":"Conversion Rate","syn":["CR","CR%","txn rate","session to order rate"],"sql":"SAFE_DIVIDE(COUNT(DISTINCT order_id),COUNT(DISTINCT sid))","note":"Hub level: SAFE_DIVIDE(All_Orders,Relevant_Sessions) from daily_hubz_rca_nat"},
{"m":"Cancel Rate","syn":["cancellation rate","cancellation ratio"],"sql":"SAFE_DIVIDE(COUNTIF(order_status='canceled'),COUNT(DISTINCT order_id))","src":"daily_orders","filters":["order_status IN ('delivered','canceled')"],"note":"NEVER filter to delivered only — gives 0%"},
{"m":"Live Outlets","syn":["active outlets","live outlet"],"sql":"COUNT(DISTINCT outlet_code)","src":"outlet_status_complete","filters":["status='active'","is_consumer_visible='1'","outlet_deleted=0"],"note":"No day filter — snapshot. is_consumer_visible is STRING '1'."},
{"m":"Churn Flag (30d)","syn":["churned","30 day churn"],"note":"0 delivered orders in 30d after last order. Power users use 15d window.","src":"daily_orders","filters":["order_status='delivered'","country='ae'"]},
{"m":"Promo Order Ratio","syn":["promo rate","discount rate"],"sql":"SAFE_DIVIDE(COUNTIF(Promo_name IS NOT NULL),COUNT(DISTINCT order_id))","src":"daily_orders","filters":["order_status='delivered'"]},
{"m":"Burn","syn":["noon burn","subsidy","noon funded burn"],"sql":"-1*SUM(IF(RestoOwnDelivery=1, noon_funded+delivery_subsidy, noon_funded))","src":"daily_orders","filters":["order_status='delivered'"],"note":"noon_funded is negative. RestoOwnDelivery=1 adds delivery_subsidy."},
{"m":"Burn per Order","syn":["average burn","subsidy per order"],"sql":"SAFE_DIVIDE(Burn, COUNT(DISTINCT order_id))"},
{"m":"Channel Discount","syn":["noon discount","platform discount"],"sql":"-1*SUM(Channel_discount)","note":"Stored negative — flip sign"},
{"m":"Outlet Discount","syn":["restaurant discount","merchant discount"],"sql":"SUM(Outlet_discount)","note":"Stored positive — no flip"},
{"m":"TPC","syn":["orders per customer","frequency"],"sql":"SAFE_DIVIDE(COUNT(DISTINCT order_id),COUNT(DISTINCT customer_id))","filters":["order_status='delivered'"]},
{"m":"High-Value PC","syn":["HPC","heavy user"],"def":"≥11 delivered orders in last 30d","sql":"COUNT(DISTINCT customer_id) WHERE orders_30d>=11","note":"Tiers: LVC(<4), Low-Value PC(4-10), High-Value PC(11+)"},
{"m":"Low-Value PC","syn":["PCL"],"def":"4-10 delivered orders in last 30d"},
{"m":"Low-Value Customers","syn":["LVC","light user"],"def":"<4 delivered orders in last 30d"},
{"m":"Weekly Reactivation Rate","syn":["reactivation rate","winback rate"],"sql":"SAFE_DIVIDE(active last 7d NOT prior 7d, active last 14d)","note":"Excludes new customers. ≠ Retention (retention=active in both windows)"},
{"m":"Retention Rate","syn":["weekly retention"],"sql":"SAFE_DIVIDE(customers in both weeks, customers in prior week)","filters":["order_status='delivered'"]},
{"m":"Noon ONE CX","syn":["N1 customers","VIP subscribers"],"sql":"COUNT(DISTINCT customer_id) WHERE is_vip_customer=true"},
{"m":"Inactive Customers","syn":["dormant","lapsed"],"def":"0 delivered orders in last N days (default N=30)"},
{"m":"CR %","syn":["conversion rate","OA rate"],"sql":"SAFE_DIVIDE(All_Orders,Relevant_Sessions)","src":"daily_hubz_rca_nat","note":"Raw event level: SAFE_DIVIDE(COUNT(DISTINCT CASE WHEN event_type='transaction' THEN sid END), COUNT(DISTINCT CASE WHEN is_bounce<>1 AND is_moved<>1 THEN sid END))"},
{"m":"Session to Outlet %","syn":["OA rate","outlet visit rate"],"sql":"SAFE_DIVIDE(SUM(Rel_OA),SUM(Relevant_Sessions))","src":"daily_hubz_rca_nat"},
{"m":"Outlet to ATC %","syn":["ATC rate","add to cart rate"],"sql":"SAFE_DIVIDE(SUM(Rel_ATC),SUM(Rel_OA))","src":"daily_hubz_rca_nat"},
{"m":"ATC to Order %","syn":["checkout conversion","cart conversion"],"sql":"SAFE_DIVIDE(SUM(Rel_Txn),SUM(Rel_ATC))","src":"daily_hubz_rca_nat"},
{"m":"LMD Distance","syn":["last mile distance","delivery distance"],"sql":"AVG(LMD)","src":"daily_orders"},
{"m":"O2D","syn":["order to delivery","total delivery time"],"sql":"AVG(Delivery_time)","src":"daily_orders","filters":["order_status='delivered'"],"note":"In mp_order_base_mat: O2D col but in SECONDS — divide by 60"},
{"m":"SLA Breach Rate","syn":["late delivery rate","O2D breach rate"],"sql":"SAFE_DIVIDE(COUNTIF(O2D_breach_consumer=1),COUNT(DISTINCT order_id))","filters":["order_status='delivered'"]},
{"m":"Outlet Impressions","syn":["outlet funnel"],"sql":"SUM(Outlet_Impressions)","src":"outlet_dod_funnel","note":"≠ Rel_OV (outlet view = menu page opened)"},
{"m":"Outlet Conversion Rate","syn":["outlet CVR"],"sql":"SAFE_DIVIDE(SUM(Rel_C),SUM(Outlet_Impressions))","src":"outlet_dod_funnel"},
{"m":"Review Rate","sql":"SAFE_DIVIDE(COUNT(DISTINCT order_nr FROM food_order_review), COUNT(DISTINCT order_id FROM daily_orders WHERE order_status='delivered'))"},
{"m":"Flash Orders","sql":"COUNT(DISTINCT order_id) WHERE order_status='delivered' AND is_flash=true","src":"daily_orders"},
{"m":"Mix Orders","sql":"COUNT(DISTINCT order_nr) WHERE order_status='delivered'","src":"nnoonbifood.growthv1.mealplan_daily_orders"},
{"m":"Ping Orders","sql":"COUNT(DISTINCT order_nr) WHERE order_status='delivered'","src":"noondwh.fdping_ping.ping_order"},
{"m":"VIP Orders","sql":"COUNT(DISTINCT order_id) WHERE is_vip=1"},
{"m":"Delayed Orders","syn":["late orders","SLA breach orders"],"sql":"COUNT(DISTINCT order_id) WHERE Delivery_time>est_delivery_time","filters":["order_status='delivered'"]},
{"m":"Cancelled Orders","sql":"COUNT(DISTINCT order_id) WHERE order_status IN ('cancelled','canceled')"},
{"m":"Commissionable GMV","sql":"SUM(total_order_amount+rest_funded)","note":"≠ GMV; includes outlet-funded discounts added back"},
{"m":"Burn per Order","sql":"SAFE_DIVIDE(Burn, COUNT(DISTINCT order_id))"},
{"m":"Kitchen Time","syn":["prep time"],"sql":"AVG(Kitchen_time)","note":"= A2RFP in mp_order_base_mat (seconds)"},
{"m":"Pickup Orders","sql":"COUNT(DISTINCT order_id) WHERE delivery_type='self_pickup'"},
{"m":"Scheduled Orders","sql":"COUNT(DISTINCT order_id) WHERE schedule_delivery IS NOT NULL"},
{"m":"Mweb Orders","sql":"COUNT(DISTINCT order_id) WHERE platform='web'"}
]}